{
	"name": "lgbtq-css-ws",
	"private": true,
	"packageManager": "npm@11.5.1",
	"workspaces": [
		"lgbtq",
		"docs"
	],
	"devDependencies": {
		"prettier": "^3.8.4"
	},
	"scripts": {
		"build": "npm run build --workspaces",
		"dev": "npm run dev --workspace docs",
		"lint": "prettier --check .",
		"format": "prettier --write ."
	},
	"prettier": {
		"printWidth": 85,
		"singleQuote": false,
		"tabWidth": 2,
		"useTabs": true,
		"bracketSpacing": true
	}
}
