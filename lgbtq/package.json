{
	"name": "lgbtq.css",
	"version": "2.0.7",
	"description": "Add some Pride to your stylesheets",
	"main": "./dist/lgbtq.css",
	"browser": "./dist/lgbtq.min.css",
	"files": [
		"./dist/lgbtq.css"
	],
	"scripts": {
		"prepublish": "npm run build",
		"build": "postcss src/index.css -o dist/lgbtq.css && postcss dist/lgbtq.css --env production -o dist/lgbtq.min.css"
	},
	"author": "Charlie <charlespeters42@gmail.com>",
	"license": "Unlicense",
	"devDependencies": {
		"autoprefixer": "^10.5.0",
		"cssnano": "^7.1.9",
		"postcss": "^8.5.15",
		"postcss-cli": "^11.0.1",
		"postcss-import": "^16.1.1",
		"postcss-reporter": "^7.1.0"
	},
	"browserslist": [
		"last 3 versions",
		"> 5%",
		"ff >= 10"
	],
	"repository": "charliewilco/lgbtq.css",
	"keywords": [
		"pride",
		"css",
		"gradients"
	],
	"bugs": {
		"url": "https://github.com/charliewilco/lgbtq.css/issues"
